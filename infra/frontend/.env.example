# =============================================================================
# LouvorFlow Frontend — Environment Variables (Deploy)
# =============================================================================
# O frontend NÃO usa env_file em runtime (VITE_* são embeddadas no build).
# Este .env é usado apenas pelo docker compose para variáveis de proxy.
# =============================================================================

# =============================================================================
# Variáveis de CI/CD (geradas automaticamente pelo pipeline)
# =============================================================================
# IMAGE_TAG=staging          # Gerado pelo workflow
# NGINX_NETWORK_NAME=        # GitHub Secret (compartilhado)
# VIRTUAL_HOST=              # GitHub Secret (environment-specific)

# =============================================================================
# Build-time secrets (passados como Docker build-args, NÃO neste .env)
# =============================================================================
# VITE_API_BASE_URL=https://api.example.com/api  # GitHub Secret → build-arg
