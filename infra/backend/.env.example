# =============================================================================
# LouvorFlow Backend — Environment Variables (Deploy)
# =============================================================================
# Estas variáveis são configuradas como GitHub Secrets no environment
# (staging/production) e injetadas no container via Generate .env no workflow.
# =============================================================================

# Server
HOST=0.0.0.0
PORT=3000

# Database (PostgreSQL connection string)
DB_URL=postgresql://user:password@host:5432/louvorflow?schema=public

# Auth — Access Token (OBRIGATÓRIO em produção)
APP_SECRET=CHANGE_THIS_TO_RANDOM_256_BIT_SECRET
ACCESS_TOKEN_EXPIRES_IN=1h

# Auth — Refresh Token (OBRIGATÓRIO em produção)
APP_SECRET_REFRESH_TOKEN=CHANGE_THIS_TO_DIFFERENT_RANDOM_256_BIT_SECRET
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_TOKEN_EXPIRES_DAYS=30

# App URLs (incluir protocolo https://)
APP_API_URL=https://api.example.com
APP_WEB_URL=https://app.example.com

# Environment
NODE_ENV=production

# Admin Seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
ADMIN_NAME=Administrador

# SMTP (produção only)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# =============================================================================
# Variáveis de CI/CD (geradas automaticamente pelo pipeline)
# =============================================================================
# IMAGE_TAG=staging          # Gerado pelo workflow
# NGINX_NETWORK_NAME=        # GitHub Secret (compartilhado)
# VIRTUAL_HOST=              # GitHub Secret (environment-specific)
