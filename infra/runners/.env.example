# ==========================================
# LouvorFlow — GitHub Actions Runner
# ==========================================
# Copiar para .env e preencher antes de subir o compose.
# NUNCA versionar o .env real — apenas este template.

# GitHub Personal Access Token (scope: repo)
# Gerar em: https://github.com/settings/tokens
# Permissões necessárias: repo (full control of private repositories)
ACCESS_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Runner labels — define o ambiente do servidor
# Usar 'staging' no servidor 192.168.0.6 (louvorflow.chewiesoft.com)
# Usar 'production' no servidor de produção
RUNNER_LABELS=staging
