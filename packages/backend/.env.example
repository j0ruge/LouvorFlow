# Server
# HOST=0.0.0.0 expõe o servidor a todas as interfaces de rede.
# Use localhost para desenvolvimento local; 0.0.0.0 apenas dentro de containers.
HOST=localhost
PORT=3000

# Database
DB_NAME=louvorflow
DB_HOST=localhost
DB_PORT=35432
DB_USER=admin
DB_PASSWORD=admin
DB_URL="postgresql://admin:admin@localhost:35432/louvorflow?schema=public"

# JWT (legacy — substituído por APP_SECRET abaixo)
JWT_SECRET=
JWT_EXPIRES_IN=

# Auth — Access Token
APP_SECRET=my-access-token-secret
ACCESS_TOKEN_EXPIRES_IN=1h

# Auth — Refresh Token
APP_SECRET_REFRESH_TOKEN=my-refresh-token-secret
# REFRESH_TOKEN_EXPIRES_IN — string usada pelo JWT (jwt.sign expiresIn). Ex: "30d", "7d".
REFRESH_TOKEN_EXPIRES_IN=30d
# REFRESH_TOKEN_EXPIRES_DAYS — número inteiro de dias usado para calcular expires_date no banco (dateProvider.addDays).
# IMPORTANTE: manter sincronizado com REFRESH_TOKEN_EXPIRES_IN para evitar divergência entre expiração JWT e DB.
REFRESH_TOKEN_EXPIRES_DAYS=30

# Auth — Admin Seed
ADMIN_EMAIL=admin@louvorflow.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_NAME=Administrador

# App URLs
APP_API_URL=http://localhost:3000
APP_WEB_URL=http://localhost:5173
